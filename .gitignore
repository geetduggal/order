node_modules/
.DS_Store

# Per-machine env overrides (e.g. VITE_VAULT_SUBPATH for a different vault path)
.env.local
.env.*.local

# Vite output (populated by `pnpm build`); keep an empty dist/ so Tauri's
# `generate_context!` macro validates the configured path.
dist/*
!dist/.gitkeep
*.log

# Rust
src-tauri/target/
src-tauri/gen/

# Tauri Mobile generated
src-tauri/gen/apple/
src-tauri/gen/android/

# Editor
.vscode/
.idea/
tsconfig.tsbuildinfo

# Viewer bundle output — produced by `pnpm build:viewer`; keep an
# empty dist-viewer/ so `tauri:dev` doesn't fail before the user
# has built the viewer for the first time.
dist-viewer/*
!dist-viewer/.gitkeep
